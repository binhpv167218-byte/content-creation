{
  "manifest_version": 3,
  "name": "Zalo Sales Assistant",
  "version": "1.0",
  "description": "Phân tích phase khách hàng từ chat Zalo, gợi ý tin nhắn tiếp theo",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://chat.zalo.me/*", "http://localhost:7788/*"],
  "content_scripts": [
    {
      "matches": ["https://chat.zalo.me/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
