# Cloudinary — lưu ảnh posts, lấy URL cho Airtable + workflow auto-post
# Đăng ký tại: https://cloudinary.com (free tier: 25GB)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Kie.ai API — dùng để generate AI infographic
# Đăng ký tại: https://kie.ai
KIE_AI_API_KEY=your_kie_ai_api_key_here

# Perplexity API — dùng để research thời gian thực (model: sonar-pro)
# Đăng ký tại: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Apify API — dùng để scrape dữ liệu social media (TikTok, YouTube, Facebook)
# Đăng ký tại: https://apify.com
APIFY_API_KEY=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
