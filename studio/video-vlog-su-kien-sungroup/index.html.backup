<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080, height=1920" />
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <style>
      @font-face {
        font-family: "Be Vietnam Pro";
        font-weight: 300;
        src:
          url("fonts/BeVietnamPro-Light-vietnamese.woff2")
            format("woff2"),
          url("fonts/BeVietnamPro-Light-latin.woff2") format("woff2");
      }
      @font-face {
        font-family: "Be Vietnam Pro";
        font-weight: 400;
        src:
          url("fonts/BeVietnamPro-Regular-vietnamese.woff2")
            format("woff2"),
          url("fonts/BeVietnamPro-Regular-latin.woff2")
            format("woff2");
      }
      @font-face {
        font-family: "Be Vietnam Pro";
        font-weight: 600;
        src:
          url("fonts/BeVietnamPro-SemiBold-vietnamese.woff2")
            format("woff2"),
          url("fonts/BeVietnamPro-SemiBold-latin.woff2")
            format("woff2");
      }
      @font-face {
        font-family: "Be Vietnam Pro";
        font-weight: 900;
        src:
          url("fonts/BeVietnamPro-Black-vietnamese.woff2")
            format("woff2"),
          url("fonts/BeVietnamPro-Black-latin.woff2") format("woff2");
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        width: 1080px;
        height: 1920px;
        overflow: hidden;
        background: #0a0a0a;
        font-family: "Be Vietnam Pro", system-ui, sans-serif;
        cursor: none;
      }

      /* ── Background clips ── */
      .bg-vid {
        position: absolute;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        opacity: 0;
      }

      /* ── Bottom gradient only — vlog style ── */
      #bot-grad {
        position: absolute;
        z-index: 2;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 960px;
        background: linear-gradient(
          to bottom,
          transparent 0%,
          rgba(0, 0, 0, 0.68) 100%
        );
        pointer-events: none;
      }

      /* ── Caption layer ── */
      #cap-layer {
        position: absolute;
        inset: 0;
        z-index: 10;
        pointer-events: none;
      }

      /* Base caption */
      .cap {
        position: absolute;
        left: 72px;
        right: 72px;
        opacity: 0;
      }

      /* Hook — big centered title — YELLOW */
      .cap-hook {
        top: 820px;
        text-align: center;
        font-size: 92px;
        font-weight: 900;
        color: #f5d878;
        line-height: 1.05;
        text-shadow: 0 4px 32px rgba(245, 216, 120, 0.4);
      }
      .cap-hook-sub {
        top: 1010px;
        text-align: center;
        font-size: 50px;
        font-weight: 400;
        color: rgba(245, 216, 120, 0.8);
        line-height: 1.35;
      }
      .cap-hook-cue {
        top: 1140px;
        text-align: center;
        font-size: 44px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.4;
      }

      /* Body — bottom safe zone — WHITE */
      .cap-body {
        bottom: 430px;
        font-size: 52px;
        font-weight: 600;
        color: #ffffff;
        line-height: 1.35;
        text-align: left;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
      }

      /* ── CTA scene ── */
      #cta {
        position: absolute;
        inset: 0;
        z-index: 15;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 28px;
        opacity: 0;
        padding: 200px 64px 400px;
        background: rgba(0, 0, 0, 0.55);
      }
      .cta-avatar {
        width: 336px;
        height: 336px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid rgba(245, 216, 120, 0.6);
        box-shadow: 0 0 40px rgba(245, 216, 120, 0.3);
        opacity: 0;
      }
      .cta-main {
        font-size: 72px;
        font-weight: 900;
        color: #f5d878;
        text-align: center;
        line-height: 1.1;
        opacity: 0;
        text-shadow:
          0 2px 20px rgba(0, 0, 0, 0.9),
          0 0 40px rgba(0, 0, 0, 0.7);
      }
      .cta-sub {
        font-size: 40px;
        font-weight: 600;
        color: #ffffff;
        text-align: center;
        line-height: 1.4;
        opacity: 0;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.9);
      }
      .cta-name {
        font-size: 32px;
        font-weight: 600;
        color: #ffffff;
        text-align: center;
        margin-top: 12px;
        opacity: 0;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
      }
      .cta-name span {
        color: #ffd966;
      }

      /* ── Branding badge — top-right ── */
      #brand-badge {
        position: absolute;
        top: 248px;
        right: 72px;
        font-size: 26px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.6);
        letter-spacing: 0.5px;
        z-index: 11;
        opacity: 0;
      }
      #brand-badge span {
        color: #ffd966;
      }
    </style>
  </head>
  <body>
    <div
      id="root"
      data-composition-id="video-vlog-su-kien-sungroup"
      data-start="0"
      data-duration="80"
      data-width="1080"
      data-height="1920"
    >
      <!-- ── 8 background clips ── -->
      <!-- c01: van-phong-ban-hang 10s — S0 0-11s -->
      <video
        id="c01"
        class="bg-vid clip"
        src="assets/c01.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="0"
        data-duration="11"
        data-track-index="1"
        data-volume="0"
      ></video>

      <!-- c02: khach-hang-su-kien 5s — S1a 11-16s -->
      <video
        id="c02"
        class="bg-vid clip"
        src="assets/c02.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="11"
        data-duration="5"
        data-track-index="2"
        data-volume="0"
      ></video>

      <!-- c03: nhac-su-kien 6s — S1b 16-20s -->
      <video
        id="c03"
        class="bg-vid clip"
        src="assets/c03.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="16"
        data-duration="5"
        data-track-index="3"
        data-volume="0"
      ></video>

      <!-- c04: bong-bay 12s — S2 20-30s (reused S6 60-66s via JS reset) -->
      <video
        id="c04"
        class="bg-vid clip"
        src="assets/c04.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="20"
        data-duration="10"
        data-track-index="4"
        data-volume="0"
      ></video>

      <!-- c05: sa-ban-1-2-3-5 7s — S3a 30-37s -->
      <video
        id="c05"
        class="bg-vid clip"
        src="assets/c05.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="30"
        data-duration="7"
        data-track-index="5"
        data-volume="0"
      ></video>

      <!-- c06: sa-ban-symphony5 6s — S3b 37-42s + S7 CTA bg 74-80s -->
      <video
        id="c06"
        class="bg-vid clip"
        src="assets/c06.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="37"
        data-duration="5"
        data-track-index="6"
        data-volume="0"
      ></video>

      <!-- c07: khach-hang-xem-sa-ban 10s — S4 42-50s + S6b 66-74s via JS -->
      <video
        id="c07"
        class="bg-vid clip"
        src="assets/c07.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="42"
        data-duration="8"
        data-track-index="7"
        data-volume="0"
      ></video>

      <!-- c08: clip-A 12s — S5 50-60s -->
      <video
        id="c08"
        class="bg-vid clip"
        src="assets/c08.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="50"
        data-duration="10"
        data-track-index="8"
        data-volume="0"
      ></video>

      <!-- c04b: ban-giao-so-do 7s — S6a 60-67s -->
      <video
        id="c04b"
        class="bg-vid clip"
        src="assets/c04b.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="60"
        data-duration="7"
        data-track-index="9"
        data-volume="0"
      ></video>

      <!-- c07b: khach-hang-xem replay — S6b 66-74s -->
      <video
        id="c07b"
        class="bg-vid clip"
        src="assets/c07b.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="66"
        data-duration="8"
        data-track-index="10"
        data-volume="0"
      ></video>

      <!-- c06b: sa-ban-symphony5 — S7 CTA bg 74-80s -->
      <video
        id="c06b"
        class="bg-vid clip"
        src="assets/c06b.mp4"
        muted
        preload="metadata"
        playsinline
        data-start="74"
        data-duration="6"
        data-track-index="11"
        data-volume="0"
      ></video>

      <!-- ── Bottom gradient ── -->
      <div id="bot-grad"></div>

      <!-- ── BGM vlog-track3 ── -->
      <audio
        id="bgm"
        class="clip"
        src="assets/bgm.mp3"
        preload="metadata"
        data-start="0"
        data-duration="80"
        data-track-index="0"
        data-volume="0.2"
      ></audio>

      <!-- ── VO segments ── -->
      <audio
        id="vo0"
        class="clip"
        src="assets/vo_s0.mp3"
        preload="metadata"
        data-start="0.3"
        data-duration="6"
        data-track-index="20"
        data-volume="1"
      ></audio>
      <audio
        id="vo1"
        class="clip"
        src="assets/vo_s1.mp3"
        preload="metadata"
        data-start="11.2"
        data-duration="6"
        data-track-index="21"
        data-volume="1"
      ></audio>
      <audio
        id="vo2"
        class="clip"
        src="assets/vo_s2.mp3"
        preload="metadata"
        data-start="20.2"
        data-duration="7"
        data-track-index="22"
        data-volume="1"
      ></audio>
      <audio
        id="vo3"
        class="clip"
        src="assets/vo_s3.mp3"
        preload="metadata"
        data-start="30.2"
        data-duration="10"
        data-track-index="23"
        data-volume="1"
      ></audio>
      <audio
        id="vo4"
        class="clip"
        src="assets/vo_s4.mp3"
        preload="metadata"
        data-start="42.2"
        data-duration="6"
        data-track-index="24"
        data-volume="1"
      ></audio>
      <audio
        id="vo5"
        class="clip"
        src="assets/vo_s5.mp3"
        preload="metadata"
        data-start="50.2"
        data-duration="8"
        data-track-index="25"
        data-volume="1"
      ></audio>
      <audio
        id="vo6"
        class="clip"
        src="assets/vo_s6.mp3"
        preload="metadata"
        data-start="60.2"
        data-duration="12"
        data-track-index="26"
        data-volume="1"
      ></audio>
      <audio
        id="vo7"
        class="clip"
        src="assets/vo_s7.mp3"
        preload="metadata"
        data-start="74.2"
        data-duration="3"
        data-track-index="27"
        data-volume="1"
      ></audio>

      <!-- ── SFX ── -->
      <audio
        id="sfx-hook-w"
        class="clip"
        src="assets/sfx_whoosh.mp3"
        preload="metadata"
        data-start="0"
        data-duration="2"
        data-track-index="30"
        data-volume="0.5"
      ></audio>
      <audio
        id="sfx-hook-p"
        class="clip"
        src="assets/sfx_pop.mp3"
        preload="metadata"
        data-start="0.35"
        data-duration="1"
        data-track-index="31"
        data-volume="0.4"
      ></audio>
      <audio
        id="sfx-cta-p"
        class="clip"
        src="assets/sfx_pop.mp3"
        preload="metadata"
        data-start="74"
        data-duration="1"
        data-track-index="32"
        data-volume="0.4"
      ></audio>
      <audio
        id="sfx-cta-w"
        class="clip"
        src="assets/sfx_whoosh.mp3"
        preload="metadata"
        data-start="74.3"
        data-duration="2"
        data-track-index="33"
        data-volume="0.3"
      ></audio>

      <!-- ── Caption layer ── -->
      <div id="cap-layer">
        <!-- S0 Hook -->
        <div id="c-s0-1" class="cap cap-hook">
          Sale chưa có khách<br />thì làm gì?
        </div>
        <div id="c-s0-2" class="cap cap-hook-sub">
          Bình dẫn bạn vào xem sự kiện Sun Group.
        </div>
        <div id="c-s0-3" class="cap cap-hook-cue">Bình Phan · IQI Đà Nẵng</div>

        <!-- S1 -->
        <div id="c-s1-1" class="cap cap-body">
          Không phải sự kiện<br />ra mắt thông thường.
        </div>
        <div id="c-s1-2" class="cap cap-body">
          Đây là lễ bàn giao<br /><strong>sổ đỏ thật sự.</strong>
        </div>
        <div id="c-s1-3" class="cap cap-body">
          <em>Cư dân nhận giấy tờ,<br />chụp ảnh, bắt tay.</em>
        </div>

        <!-- S2 -->
        <div id="c-s2-1" class="cap cap-body">Mình để ý kỹ hơn.</div>
        <div id="c-s2-2" class="cap cap-body">
          Khách hôm nay<br />không chủ yếu từ Đà Nẵng.
        </div>
        <div id="c-s2-3" class="cap cap-body">
          Hà Nội, Sài Gòn<br />chiếm gần <strong>một nửa.</strong><br /><em
            >Tín hiệu cần để ý.</em
          >
        </div>

        <!-- S3 -->
        <div id="c-s3-1" class="cap cap-body">Sa bàn tổ hợp Symphony.</div>
        <div id="c-s3-2" class="cap cap-body">
          Bốn tháp:<br /><strong>1, 2, 3 và 5.</strong>
        </div>
        <div id="c-s3-3" class="cap cap-body">
          <strong>1, 2, 3</strong> vừa bàn giao.
        </div>
        <div id="c-s3-4" class="cap cap-body">
          <strong>Symphony 5</strong><br />đang mở bán.
        </div>
        <div id="c-s3-5" class="cap cap-body">
          <em>Cùng 1 sự kiện,<br />2 câu chuyện.</em>
        </div>

        <!-- S4 -->
        <div id="c-s4-1" class="cap cap-body">Mình nhận ra:</div>
        <div id="c-s4-2" class="cap cap-body">
          Khách đứng ở sa bàn<br />lâu hơn nghe thuyết trình.
        </div>
        <div id="c-s4-3" class="cap cap-body">
          Người ta mua bằng <strong>hình ảnh.</strong><br /><em
            >Không phải con số.</em
          >
        </div>

        <!-- S5 -->
        <div id="c-s5-1" class="cap cap-body">
          Cái mình thích nhất<br />ở sự kiện như vầy:
        </div>
        <div id="c-s5-2" class="cap cap-body">
          Cuộc trò chuyện<br /><strong>không có trong kịch bản.</strong>
        </div>
        <div id="c-s5-3" class="cap cap-body">
          <em>Đó là lúc học được<br />nhiều nhất.</em>
        </div>

        <!-- S6 -->
        <div id="c-s6-1" class="cap cap-body">
          Mình qua nhiều<br />sự kiện rồi.
        </div>
        <div id="c-s6-2" class="cap cap-body">
          Nhưng lễ bàn giao sổ đỏ<br />thật sự <strong>khác.</strong>
        </div>
        <div id="c-s6-3" class="cap cap-body">
          Cư dân cầm tờ giấy đó,<br />mặt họ khác.
        </div>
        <div id="c-s6-4" class="cap cap-body">
          Không phải vì<br />giá trị tài sản.
        </div>
        <div id="c-s6-5" class="cap cap-body">
          Mà vì <strong>lời hứa được giữ.</strong>
        </div>
        <div id="c-s6-6" class="cap cap-body">
          <em>Hôm nay có một khách<br />hỏi Bình một câu...</em>
        </div>
        <div id="c-s6-7" class="cap cap-body"><em>Video sau mình kể.</em></div>
      </div>

      <!-- ── Branding badge S0 ── -->
      <div id="brand-badge">Bình Phan <span>IQI</span></div>

      <!-- ── CTA S7 ── -->
      <div id="cta">
        <img
          id="cta-avatar"
          class="cta-avatar clip"
          src="assets/me-outtro.jpg"
          alt=""
          data-start="74"
          data-duration="6"
          data-track-index="50"
          data-volume="0"
        />
        <div
          id="cta-main"
          class="cta-main clip"
          data-start="74"
          data-duration="6"
          data-track-index="51"
          data-volume="0"
          style="opacity: 0"
        >
          Theo dõi Bình
        </div>
        <div
          id="cta-sub"
          class="cta-sub clip"
          data-start="74"
          data-duration="6"
          data-track-index="52"
          data-volume="0"
          style="opacity: 0"
        >
          để xem thêm hậu trường<br />như vầy nhé.
        </div>
        <div
          id="cta-name"
          class="cta-name clip"
          data-start="74"
          data-duration="6"
          data-track-index="53"
          data-volume="0"
          style="opacity: 0"
        >
          Bình Phan <span>IQI</span>
        </div>
      </div>
    </div>

    <script>
      /* ─── helpers ─── */

      /* Slide-in a caption element */
      function showCap(id, t, dur) {
        tl.fromTo(
          `#${id}`,
          { opacity: 0, y: 18 },
          { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" },
          t,
        );
        if (dur) {
          tl.to(
            `#${id}`,
            { opacity: 0, y: -8, duration: 0.25, ease: "power2.in" },
            t + dur,
          );
        }
      }

      /* zoomCut disabled — causes compositor stall in headless render */
      function zoomCut(t) {}

      /* ─── Build timeline ─── */
      const tl = gsap.timeline({ paused: true });

      /* ── Video clip opacity — explicit GSAP (HyperFrames fallback) ── */
      // S0 0-11s
      tl.fromTo("#c01", { opacity: 0 }, { opacity: 1, duration: 0.4 }, 0);
      tl.to("#c01", { opacity: 0, duration: 0.3 }, 10.7);
      // S1 11-20s
      tl.fromTo("#c02", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 11);
      tl.to("#c02", { opacity: 0, duration: 0.3 }, 15.7);
      tl.fromTo("#c03", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 16);
      tl.to("#c03", { opacity: 0, duration: 0.3 }, 19.7);
      // S2 20-30s
      tl.fromTo("#c04", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 20);
      tl.to("#c04", { opacity: 0, duration: 0.3 }, 29.7);
      // S3 30-42s
      tl.fromTo("#c05", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 30);
      tl.to("#c05", { opacity: 0, duration: 0.3 }, 36.7);
      tl.fromTo("#c06", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 37);
      tl.to("#c06", { opacity: 0, duration: 0.3 }, 41.7);
      // S4 42-50s
      tl.fromTo("#c07", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 42);
      tl.to("#c07", { opacity: 0, duration: 0.3 }, 49.7);
      // S5 50-60s
      tl.fromTo("#c08", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 50);
      tl.to("#c08", { opacity: 0, duration: 0.3 }, 59.7);
      // S6 60-74s
      tl.fromTo("#c04b", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 60);
      tl.to("#c04b", { opacity: 0, duration: 0.3 }, 66.7);
      tl.fromTo("#c07b", { opacity: 0 }, { opacity: 1, duration: 0.3 }, 66);
      tl.to("#c07b", { opacity: 0, duration: 0.3 }, 73.7);
      // S7 CTA 74-80s — c06b riêng
      tl.fromTo("#c06b", { opacity: 0 }, { opacity: 1, duration: 0.5 }, 74);

      /* ════ S0 HOOK  0-11s ════ */
      // Brand badge
      tl.fromTo(
        "#brand-badge",
        { opacity: 0, y: 8 },
        { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" },
        0.4,
      );
      tl.to("#brand-badge", { opacity: 0, duration: 0.4 }, 4.5);

      // Hook captions — sync with VO timestamps
      showCap("c-s0-1", 0.3, 1.3); // "SỰ KIỆN BÀN GIAO SỔ ĐỎ" — 0s
      showCap("c-s0-2", 1.9, 2.1); // "cho cư dân Symphony 1, 2, 3" — 1.66+0.3 offset
      showCap("c-s0-3", 4.5, 4.0); // "Bình ở đây..." — 4.24+0.3 offset

      /* ════ S1  11-20s ════ */
      zoomCut(11);
      showCap("c-s1-1", 11.3, 1.5); // "Không phải sự kiện..." — 0s in s1
      showCap("c-s1-2", 12.9, 1.8); // "Đây là lễ bàn giao..." — 1.62s in s1
      showCap("c-s1-3", 14.9, 4.0); // "Cư dân nhận giấy tờ..." — 3.58s in s1

      /* ════ S2  20-30s ════ */
      zoomCut(20);
      showCap("c-s2-1", 20.3, 0.9); // "Mình để ý kỹ hơn." — 0s
      showCap("c-s2-2", 21.5, 1.9); // "Khách không chủ yếu..." — 1.2s
      showCap("c-s2-3", 23.3, 5.5); // "Hà Nội, Sài Gòn..." — 3.08s

      /* ════ S3  30-42s ════ */
      zoomCut(30);
      showCap("c-s3-1", 30.3, 1.8); // "Sa bàn..." — word 0.0s
      showCap("c-s3-2", 32.4, 2.3); // "Bốn tháp..." — word 2.0s
      showCap("c-s3-3", 35.1, 1.5); // "1,2,3 vừa bàn giao" — word 4.74s
      showCap("c-s3-4", 37.0, 1.1); // "Symphony 5 mở bán" — word 6.6s
      showCap("c-s3-5", 38.4, 3.3); // "Cùng 1 sự kiện, 2 câu chuyện" — word 8.0s

      /* ════ S4  42-50s ════ */
      zoomCut(42);
      showCap("c-s4-1", 42.3, 0.5); // "Mình nhận ra:"
      showCap("c-s4-2", 42.9, 2.2); // "Khách đứng ở sa bàn..." — 1.0s
      showCap("c-s4-3", 45.2, 4.0); // "Người ta mua bằng hình ảnh..." — 3.0s

      /* ════ S5  50-60s ════ */
      zoomCut(50);
      showCap("c-s5-1", 50.3, 2.0); // "Cái mình thích nhất..." — 0s
      showCap("c-s5-2", 52.5, 1.8); // "Cuộc trò chuyện..." — 2.26s
      showCap("c-s5-3", 56.2, 3.0); // "Đó là lúc học..." — 5.94s

      /* ════ S6  60-74s — c04b + c07b via data-start ════ */
      zoomCut(60);

      showCap("c-s6-1", 60.3, 1.0); // "Mình qua nhiều sự kiện rồi"
      showCap("c-s6-2", 61.7, 1.3); // "Nhưng lễ bàn giao sổ đỏ khác" — 1.36s
      showCap("c-s6-3", 63.6, 1.6); // "Cư dân cầm tờ giấy..." — 3.3s
      showCap("c-s6-4", 65.7, 1.3); // "Không phải vì giá trị..." — 5.42s
      showCap("c-s6-5", 67.2, 1.7); // "Mà vì lời hứa được giữ" — 6.96s
      showCap("c-s6-6", 68.7, 1.7); // "Hôm nay có một khách..." — 8.38s
      showCap("c-s6-7", 70.8, 3.0); // "Video sau mình kể" — 10.54s

      /* ════ S7 CTA  74-80s ════ */
      zoomCut(74);
      tl.fromTo(
        "#cta",
        { opacity: 0 },
        { opacity: 1, duration: 0.6, ease: "power2.out" },
        74,
      );
      tl.fromTo(
        "#cta-avatar",
        { opacity: 0, scale: 0.88 },
        { opacity: 1, scale: 1, duration: 0.6, ease: "back.out(1.4)" },
        74.2,
      );
      tl.fromTo(
        "#cta-main",
        { opacity: 0, y: 24 },
        { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" },
        74.5,
      );
      tl.fromTo(
        "#cta-sub",
        { opacity: 0, y: 16 },
        { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" },
        74.85,
      );
      tl.fromTo(
        "#cta-name",
        { opacity: 0, y: 10 },
        { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" },
        75.2,
      );

      /* ─── register — HyperFrames drives timeline in render ─── */
      window.__timelines = window.__timelines || {};
      window.__timelines["video-vlog-su-kien-sungroup"] = tl;
    </script>
  </body>
</html>
